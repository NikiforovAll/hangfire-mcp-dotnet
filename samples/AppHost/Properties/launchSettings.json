{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "https://localhost:17000;http://localhost:15000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",
        "DOTNET_DASHBOARD_OTLP_ENDPOINT_URL": "https://localhost:18000",
        "DOTNET_RESOURCE_SERVICE_ENDPOINT_URL": "https://localhost:19000",
        "ASPIRE_DASHBOARD_OTLP_ENDPOINT_URL": "https://localhost:18000",
        "ASPIRE_DASHBOARD_OTLP_HTTP_ENDPOINT_URL": "https://localhost:18001",
        "ASPIRE_RESOURCE_SERVICE_ENDPOINT_URL": "https://localhost:19000",
        "ASPIRE_ALLOW_UNSECURED_TRANSPORT": "true"
      }
    },
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "http://localhost:15000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",
        "DOTNET_DASHBOARD_OTLP_ENDPOINT_URL": "http://localhost:18000",
        "DOTNET_RESOURCE_SERVICE_ENDPOINT_URL": "http://localhost:19000",
        "ASPIRE_DASHBOARD_OTLP_ENDPOINT_URL": "http://localhost:18000",
        "ASPIRE_DASHBOARD_OTLP_HTTP_ENDPOINT_URL": "http://localhost:18001",
        "ASPIRE_RESOURCE_SERVICE_ENDPOINT_URL": "http://localhost:19000",
        "ASPIRE_ALLOW_UNSECURED_TRANSPORT": "true"
      }
    }
  }
}
